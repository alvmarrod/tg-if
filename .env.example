RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

LOG_LEVEL=INFO
HEALTH_CHECK_PORT=8080

# Media cache and config paths (defaults: /data/media and /data/media/media_config.json)
# MEDIA_CACHE_PATH=./media_cache
# MEDIA_CONFIG_PATH=./media_cache/media_config.json

# Admin notifier bot config is in config/bots.json under the "admin" key.
# Requires a dedicated Telegram bot session and an admin user_id.
